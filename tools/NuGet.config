<?xml version="1.0" encoding="utf-8"?>
<!-- Scoped to tools/ — ensures the Scraibe.Publisher build only uses nuget.org,
     not any private feeds configured globally on the developer's machine. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
