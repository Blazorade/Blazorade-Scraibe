@inherits ShortCodeComponentBase

@this.HeadingContent

@code {
    [Parameter]
    [Description("The level for the heading. Can be set to 1 through 6.")]
    [Range(1, 6)]
    public int Level { get; set; } = 1;

    [Parameter]
    [Description("Allows to specify a display heading that is larger than a regular heading. Set to a value from 1 to 6. The default, `null` is used to create a regular heading.")]
    [Range(1, 6)]
    public int? Display { get; set; }

    private RenderFragment HeadingContent => builder =>
    {
        builder.OpenElement(0, $"h{this.Level}");
        builder.AddMultipleAttributes(1, this.Attributes);
        builder.AddContent(2, this.ChildContent);
        builder.CloseElement();
    };


    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if(this.Display.HasValue)
        {
            this.AddClasses($"display-{this.Display}");
        }
    }
}
