<nav class="navbar navbar-expand-lg navbar-dark main-nav">
    <div class="container">
        <a class="navbar-brand" href="/" @onclick="CloseNav">{DisplayName}</a>

        <button title="Navigation menu" class="navbar-toggler" type="button" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="@NavMenuCssClass">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <!-- Flat page — one <li> per top-level page (exclude the home page) -->
                <li class="nav-item">
                    <NavLink class="nav-link" href="/{slug}" Match="NavLinkMatch.All" @onclick="CloseNav">{title}</NavLink>
                </li>
                <!-- Subdirectory dropdowns are generated here by publish -->
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool _collapseNavMenu = true;
    private string? _openDropdownKey;

    private string NavMenuCssClass => _collapseNavMenu ? "collapse navbar-collapse" : "navbar-collapse show";

    private void ToggleNavMenu() => _collapseNavMenu = !_collapseNavMenu;

    private void CloseNav()
    {
        _collapseNavMenu = true;
        _openDropdownKey = null;
    }

    private void ToggleDropdown(string key) =>
        _openDropdownKey = string.Equals(_openDropdownKey, key, StringComparison.OrdinalIgnoreCase) ? null : key;

    private void CloseDropdown(string key)
    {
        if (string.Equals(_openDropdownKey, key, StringComparison.OrdinalIgnoreCase))
            _openDropdownKey = null;
    }

    private bool IsDropdownOpen(string key) =>
        string.Equals(_openDropdownKey, key, StringComparison.OrdinalIgnoreCase);
}
